    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sample Types</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
    <style>
        .main-content {
            padding: 2rem;
        }

        .border-sample {
            border-left: 4px solid #0dcaf0;
            padding-left: 1rem;
        }

        .btn-sample {
            background-color: #0aa2c0;
            border-color: #0aa2c0;
            color: #fff;
        }

            .btn-sample:hover {
                background-color: #087990;
                border-color: #087990;
                color: #fff;
            }

        .text-sample {
            color: #0aa2c0;
        }

        .bg-sample {
            background-color: #0dcaf0;
            color: #000;
        }

        .table thead th {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>
    <!-- SIDEBAR -->
    <div class="sidebar" style="display:flex;flex-direction:column;height:100vh;">
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>
                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Jodi Cunningham</div>
                </div>
            </div>
            <div class="profile-role">
                Laboratory Manager
            </div>
        </div>

        <div class="sidebar-bottom" style="overflow-y:auto;flex:1;">
            <div style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; color: #adb5bd; margin-top: 0.5rem;">
                Management
            </div>
            <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="sidebar-link">
                <span style="color:#6f42c1">●</span> Test Categories
            </a>
            <a asp-controller="LabManager" asp-action="TestTypeIndex" class="sidebar-link">
                <span style="color:#0d6efd">●</span> Test Types
            </a>
            <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="sidebar-link">
                <span style="color:#0dcaf0">●</span> Sample Types
            </a>
            <a asp-controller="LabManager" asp-action="ConsumableIndex" class="sidebar-link">
                <span style="color:#dc3545">●</span> Consumables
            </a>
            <a asp-controller="LabManager" asp-action="SupplierIndex" class="sidebar-link">
                <span style="color:#fd7e14">●</span> Suppliers
            </a>
            <a asp-controller="LabManager" asp-action="DoctorIndex" class="sidebar-link">
                <span style="color:#198754">●</span> Doctors
            </a>
            <a asp-controller="LabManager" asp-action="TechnicianIndex" class="sidebar-link">
                <span style="color:#6610f2">●</span> Technicians
            </a>
            <a asp-controller="LabManager" asp-action="OrderIndex" class="sidebar-link">
                <span style="color:#e8590c">●</span> Orders
            </a>

            <div class="sidebar-actions">
                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">
                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="container-fluid" style="max-width: 700px;">
            <div class="mb-4 border-sample">
                <h2 class="h4 mb-0">Sample Types</h2>
                <small class="text-muted">Maintain the list of specimen types accepted by the laboratory</small>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form asp-controller="LabManager" asp-action="SampleTypeCreate" method="post" class="row g-2 align-items-end">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">New Sample Type <span class="text-danger">*</span></label>
                            <input type="text" name="SampleTypeName" class="form-control" placeholder="e.g. Whole blood, Plasma, Bone marrow" required />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-sample w-100"><i class="fa-solid fa-plus me-2"></i>Add Sample Type</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-sample"><tr><th>Sample Type Name</th><th class="text-end" style="width:120px">Actions</th></tr></thead>
                        <tbody>
                            <tr><td>Whole blood</td><td class="text-end"><button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-trash"></i></button></td></tr>
                            <tr><td>Plasma</td><td class="text-end"><button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-trash"></i></button></td></tr>
                            <tr><td>Bone marrow</td><td class="text-end"><button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-trash"></i></button></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
