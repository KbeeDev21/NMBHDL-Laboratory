@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Test Categories</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
    <style>
        .main-content {
            padding: 2rem;
        }

        .border-cat {
            border-left: 4px solid #6f42c1;
            padding-left: 1rem;
        }

        .btn-cat {
            background-color: #6f42c1;
            border-color: #6f42c1;
            color: #fff;
        }

            .btn-cat:hover {
                background-color: #5a36a6;
                border-color: #5a36a6;
                color: #fff;
            }

        .text-cat {
            color: #6f42c1;
        }

        .bg-cat {
            background-color: #6f42c1;
            color: #fff;
        }

        .table thead th {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>
    <!-- SIDEBAR -->
    <div class="sidebar" style="display:flex;flex-direction:column;height:100vh;">
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>
                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Jodi Cunningham</div>
                </div>
            </div>
            <div class="profile-role">
                Laboratory Manager
            </div>
        </div>

        <div class="sidebar-bottom" style="overflow-y:auto;flex:1;">
            <div style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; color: #adb5bd; margin-top: 0.5rem;">
                Management
            </div>
            <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="sidebar-link">
                <span style="color:#6f42c1">●</span> Test Categories
            </a>
            <a asp-controller="LabManager" asp-action="TestTypeIndex" class="sidebar-link">
                <span style="color:#0d6efd">●</span> Test Types
            </a>
            <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="sidebar-link">
                <span style="color:#0dcaf0">●</span> Sample Types
            </a>
            <a asp-controller="LabManager" asp-action="ConsumableIndex" class="sidebar-link">
                <span style="color:#dc3545">●</span> Consumables
            </a>
            <a asp-controller="LabManager" asp-action="SupplierIndex" class="sidebar-link">
                <span style="color:#fd7e14">●</span> Suppliers
            </a>
            <a asp-controller="LabManager" asp-action="DoctorIndex" class="sidebar-link">
                <span style="color:#198754">●</span> Doctors
            </a>
            <a asp-controller="LabManager" asp-action="TechnicianIndex" class="sidebar-link">
                <span style="color:#6610f2">●</span> Technicians
            </a>
            <a asp-controller="LabManager" asp-action="OrderIndex" class="sidebar-link">
                <span style="color:#e8590c">●</span> Orders
            </a>

            <div class="sidebar-actions">
                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">
                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4 border-cat">
                <div>
                    <h2 class="h4 mb-0">Test Categories</h2>
                    <small class="text-muted">Manage diagnostic test categories</small>
                </div>
                <a asp-controller="LabManager" asp-action="TestCategoryCreate" class="btn btn-cat"><i class="fa-solid fa-plus me-2"></i>Add Category</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-cat"><tr><th>Category Name</th><th>Description</th><th class="text-end" style="width:140px">Actions</th></tr></thead>
                        <tbody>
                            <tr><td>Full Blood Count</td><td>Complete blood cell analysis including RBC, WBC and platelets</td><td class="text-end"><a asp-controller="LabManager" asp-action="TestCategoryEdit" asp-route-id="1" class="btn btn-sm btn-outline-light text-white border-white"><i class="fa-solid fa-pen-to-square"></i></a> <button class="btn btn-sm btn-outline-light text-white border-white"><i class="fa-solid fa-trash"></i></button></td></tr>
                            <tr><td>Coagulation Studies</td><td>Tests to evaluate blood clotting mechanisms and bleeding disorders</td><td class="text-end"><a asp-controller="LabManager" asp-action="TestCategoryEdit" asp-route-id="2" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-pen-to-square"></i></a> <button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-trash"></i></button></td></tr>
                            <tr><td colspan="3" class="text-center text-muted py-4">No additional categories configured</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
