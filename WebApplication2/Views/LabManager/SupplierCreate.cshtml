@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Supplier</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
    <style>
        .main-content {
            padding: 2rem;
        }

        .border-supp {
            border-left: 4px solid #fd7e14;
            padding-left: 1rem;
        }

        .btn-supp {
            background-color: #fd7e14;
            border-color: #fd7e14;
            color: #fff;
        }

            .btn-supp:hover {
                background-color: #e56b0a;
                border-color: #e56b0a;
                color: #fff;
            }
    </style>
</head>
<body>
    <!-- SIDEBAR -->
    <div class="sidebar" style="display:flex;flex-direction:column;height:100vh;">
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>
                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Jodi Cunningham</div>
                </div>
            </div>
            <div class="profile-role">
                Laboratory Manager
            </div>
        </div>

        <div class="sidebar-bottom" style="overflow-y:auto;flex:1;">
            <div style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; color: #adb5bd; margin-top: 0.5rem;">
                Management
            </div>
            <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="sidebar-link">
                <span style="color:#6f42c1">●</span> Test Categories
            </a>
            <a asp-controller="LabManager" asp-action="TestTypeIndex" class="sidebar-link">
                <span style="color:#0d6efd">●</span> Test Types
            </a>
            <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="sidebar-link">
                <span style="color:#0dcaf0">●</span> Sample Types
            </a>
            <a asp-controller="LabManager" asp-action="ConsumableIndex" class="sidebar-link">
                <span style="color:#dc3545">●</span> Consumables
            </a>
            <a asp-controller="LabManager" asp-action="SupplierIndex" class="sidebar-link">
                <span style="color:#fd7e14">●</span> Suppliers
            </a>
            <a asp-controller="LabManager" asp-action="DoctorIndex" class="sidebar-link">
                <span style="color:#198754">●</span> Doctors
            </a>
            <a asp-controller="LabManager" asp-action="TechnicianIndex" class="sidebar-link">
                <span style="color:#6610f2">●</span> Technicians
            </a>
            <a asp-controller="LabManager" asp-action="OrderIndex" class="sidebar-link">
                <span style="color:#e8590c">●</span> Orders
            </a>

            <div class="sidebar-actions">
                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">
                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="container-fluid" style="max-width: 700px;">
            <div class="mb-4 border-supp">
                <h2 class="h4 mb-0">Create Supplier</h2>
                <small class="text-muted">Register a new consumable supplier</small>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-controller="LabManager" asp-action="SupplierCreate" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Supplier Name <span class="text-danger">*</span></label>
                            <input type="text" name="SupplierName" class="form-control" required />
                            <div class="form-text">Must be unique.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Contact Person <span class="text-danger">*</span></label>
                            <input type="text" name="ContactPerson" class="form-control" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                            <input type="email" name="Email" class="form-control" required />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-supp"><i class="fa-solid fa-check me-2"></i>Save Supplier</button>
                            <a asp-controller="LabManager" asp-action="SupplierIndex" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>