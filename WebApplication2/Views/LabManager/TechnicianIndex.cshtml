@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Technicians</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
    <style>
        .main-content {
            padding: 2rem;
        }

        .border-tech {
            border-left: 4px solid #6610f2;
            padding-left: 1rem;
        }

        .btn-tech {
            background-color: #6610f2;
            border-color: #6610f2;
            color: #fff;
        }

            .btn-tech:hover {
                background-color: #520dc2;
                border-color: #520dc2;
                color: #fff;
            }

        .text-tech {
            color: #6610f2;
        }

        .bg-tech {
            background-color: #6610f2;
            color: #fff;
        }

        .table thead th {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>
    <!-- SIDEBAR -->
    <div class="sidebar" style="display:flex;flex-direction:column;height:100vh;">
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>
                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Jodi Cunningham</div>
                </div>
            </div>
            <div class="profile-role">
                Laboratory Manager
            </div>
        </div>

        <div class="sidebar-bottom" style="overflow-y:auto;flex:1;">
            <div style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; color: #adb5bd; margin-top: 0.5rem;">
                Management
            </div>
            <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="sidebar-link">
                <span style="color:#6f42c1">●</span> Test Categories
            </a>
            <a asp-controller="LabManager" asp-action="TestTypeIndex" class="sidebar-link">
                <span style="color:#0d6efd">●</span> Test Types
            </a>
            <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="sidebar-link">
                <span style="color:#0dcaf0">●</span> Sample Types
            </a>
            <a asp-controller="LabManager" asp-action="ConsumableIndex" class="sidebar-link">
                <span style="color:#dc3545">●</span> Consumables
            </a>
            <a asp-controller="LabManager" asp-action="SupplierIndex" class="sidebar-link">
                <span style="color:#fd7e14">●</span> Suppliers
            </a>
            <a asp-controller="LabManager" asp-action="DoctorIndex" class="sidebar-link">
                <span style="color:#198754">●</span> Doctors
            </a>
            <a asp-controller="LabManager" asp-action="TechnicianIndex" class="sidebar-link">
                <span style="color:#6610f2">●</span> Technicians
            </a>
            <a asp-controller="LabManager" asp-action="OrderIndex" class="sidebar-link">
                <span style="color:#e8590c">●</span> Orders
            </a>

            <div class="sidebar-actions">
                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">
                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4 border-tech">
                <div>
                    <h2 class="h4 mb-0">Technicians</h2>
                    <small class="text-muted">Manage lab technicians and their test-type assignments</small>
                </div>
                <button class="btn btn-tech" data-bs-toggle="collapse" data-bs-target="#addTechnician"><i class="fa-solid fa-plus me-2"></i>Add Technician</button>
            </div>

            <div class="collapse mb-4" id="addTechnician">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <form asp-controller="LabManager" asp-action="TechnicianCreate" method="post">
                            <div class="row g-3">
                                <div class="col-md-6"><label class="form-label fw-semibold">Name <span class="text-danger">*</span></label><input type="text" name="Name" class="form-control" required /></div>
                                <div class="col-md-6"><label class="form-label fw-semibold">Surname <span class="text-danger">*</span></label><input type="text" name="Surname" class="form-control" required /></div>
                                <div class="col-md-6"><label class="form-label fw-semibold">SA ID Number <span class="text-danger">*</span></label><input type="text" name="SAIDNumber" class="form-control" placeholder="13-digit SA ID" required /></div>
                                <div class="col-md-6"><label class="form-label fw-semibold">Employee Number <span class="text-danger">*</span></label><input type="text" name="EmployeeNumber" class="form-control" required /></div>
                                <div class="col-md-6"><label class="form-label fw-semibold">Email <span class="text-danger">*</span></label><input type="email" name="Email" class="form-control" required /></div>
                                <div class="col-md-6"><label class="form-label fw-semibold">Contact Number <span class="text-danger">*</span></label><input type="tel" name="ContactNumber" class="form-control" required /></div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Assigned Test Types <span class="text-danger">*</span></label>
                                    <div class="border rounded p-3" style="max-height: 140px; overflow-y: auto;">
                                        <div class="form-check"><input class="form-check-input" type="checkbox" name="TestTypes" value="1" id="t1"><label class="form-check-label" for="t1">Haemoglobin</label></div>
                                        <div class="form-check"><input class="form-check-input" type="checkbox" name="TestTypes" value="2" id="t2"><label class="form-check-label" for="t2">PT / INR</label></div>
                                        <div class="form-check"><input class="form-check-input" type="checkbox" name="TestTypes" value="3" id="t3"><label class="form-check-label" for="t3">White Cell Count</label></div>
                                    </div>
                                    <div class="form-text">At least one test type must be assigned.</div>
                                </div>
                            </div>
                            <div class="alert alert-info mt-3 mb-0"><i class="fa-solid fa-circle-info me-2"></i>A password will be auto-generated and emailed to the technician.</div>
                            <div class="mt-3"><button type="submit" class="btn btn-tech">Register Technician</button></div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0 table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-tech"><tr><th>Name</th><th>Surname</th><th>SA ID</th><th>Employee No</th><th>Email</th><th>Test Types</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                        <tbody>
                            <tr><td>Thabo</td><td>Molefe</td><td>850101******</td><td>EMP-001</td><td>thabo@nmbhdl.co.za</td><td><span class="badge bg-light text-dark border">Haemoglobin</span> <span class="badge bg-light text-dark border">WCC</span></td><td><span class="badge bg-success">Active</span></td><td class="text-end"><button class="btn btn-sm btn-outline-light text-white border-white"><i class="fa-solid fa-pen-to-square"></i></button> <button class="btn btn-sm btn-outline-light text-white border-white"><i class="fa-solid fa-trash"></i></button></td></tr>
                            <tr><td>Lisa</td><td>Jacobs</td><td>920512******</td><td>EMP-002</td><td>lisa@nmbhdl.co.za</td><td><span class="badge bg-light text-dark border">PT / INR</span></td><td><span class="badge bg-warning text-dark">Must Change Password</span></td><td class="text-end"><button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-pen-to-square"></i></button> <button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-trash"></i></button></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
