    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Consumable Orders</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
    <style>
        .main-content {
            padding: 2rem;
        }

        .border-order {
            border-left: 4px solid #e8590c;
            padding-left: 1rem;
        }

        .btn-order {
            background-color: #e8590c;
            border-color: #e8590c;
            color: #fff;
        }

            .btn-order:hover {
                background-color: #d04f0a;
                border-color: #d04f0a;
                color: #fff;
            }

        .text-order {
            color: #e8590c;
        }

        .bg-order {
            background-color: #e8590c;
            color: #fff;
        }

        .table thead th {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>
    <!-- SIDEBAR -->
    <div class="sidebar" style="display:flex;flex-direction:column;height:100vh;">
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>
                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Jodi Cunningham</div>
                </div>
            </div>
            <div class="profile-role">
                Laboratory Manager
            </div>
        </div>

        <div class="sidebar-bottom" style="overflow-y:auto;flex:1;">
            <div style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; color: #adb5bd; margin-top: 0.5rem;">
                Management
            </div>
            <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="sidebar-link">
                <span style="color:#6f42c1">●</span> Test Categories
            </a>
            <a asp-controller="LabManager" asp-action="TestTypeIndex" class="sidebar-link">
                <span style="color:#0d6efd">●</span> Test Types
            </a>
            <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="sidebar-link">
                <span style="color:#0dcaf0">●</span> Sample Types
            </a>
            <a asp-controller="LabManager" asp-action="ConsumableIndex" class="sidebar-link">
                <span style="color:#dc3545">●</span> Consumables
            </a>
            <a asp-controller="LabManager" asp-action="SupplierIndex" class="sidebar-link">
                <span style="color:#fd7e14">●</span> Suppliers
            </a>
            <a asp-controller="LabManager" asp-action="DoctorIndex" class="sidebar-link">
                <span style="color:#198754">●</span> Doctors
            </a>
            <a asp-controller="LabManager" asp-action="TechnicianIndex" class="sidebar-link">
                <span style="color:#6610f2">●</span> Technicians
            </a>
            <a asp-controller="LabManager" asp-action="OrderIndex" class="sidebar-link">
                <span style="color:#e8590c">●</span> Orders
            </a>

            <div class="sidebar-actions">
                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">
                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4 border-order">
                <div>
                    <h2 class="h4 mb-0">Consumable Orders</h2>
                    <small class="text-muted">Track stock orders, receipts and cancellations</small>
                </div>
                <a asp-controller="LabManager" asp-action="OrderCreate" class="btn btn-order"><i class="fa-solid fa-plus me-2"></i>Create Order</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0 table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-order"><tr><th>Order No</th><th>Supplier</th><th>Date Ordered</th><th>Status</th><th>Items</th><th class="text-end" style="width:200px">Actions</th></tr></thead>
                        <tbody>
                            <tr>
                                <td class="fw-semibold">ORD-2026-001</td>
                                <td>MedSupply SA</td>
                                <td>2026-03-01</td>
                                <td><span class="badge bg-primary">Ordered</span></td>
                                <td>EDTA Tube (4ml) x50, Citrate Tube x40</td>
                                <td class="text-end"><button class="btn btn-sm btn-success"><i class="fa-solid fa-check me-1"></i>Receive</button> <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-xmark"></i></button></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">ORD-2026-002</td>
                                <td>LabWare Pty</td>
                                <td>2026-03-05</td>
                                <td><span class="badge bg-warning text-dark">Partially Complete</span></td>
                                <td>Reagent A x20 <span class="badge bg-success">Received</span>, Reagent B x10 <span class="badge bg-primary">Ordered</span></td>
                                <td class="text-end"><button class="btn btn-sm btn-success"><i class="fa-solid fa-check me-1"></i>Receive</button> <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-xmark"></i></button></td>
                            </tr>
                            <tr class="text-muted">
                                <td class="fw-semibold">ORD-2026-000</td>
                                <td>MedSupply SA</td>
                                <td>2026-02-20</td>
                                <td><span class="badge bg-success">Complete</span></td>
                                <td>EDTA Tube (4ml) x100</td>
                                <td class="text-end"><button class="btn btn-sm btn-outline-secondary" disabled>Received</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>