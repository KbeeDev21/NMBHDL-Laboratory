@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Consumables</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
    <style>
        .main-content {
            padding: 2rem;
        }

        .border-cons {
            border-left: 4px solid #dc3545;
            padding-left: 1rem;
        }

        .btn-cons {
            background-color: #dc3545;
            border-color: #dc3545;
            color: #fff;
        }

            .btn-cons:hover {
                background-color: #bb2d3b;
                border-color: #bb2d3b;
                color: #fff;
            }

        .text-cons {
            color: #dc3545;
        }

        .bg-cons {
            background-color: #dc3545;
            color: #fff;
        }

        .table thead th {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stock-low {
            background-color: #fff3f3;
        }
    </style>
</head>
<body>
<!-- SIDEBAR -->
<div class="sidebar" style="display:flex;flex-direction:column;height:100vh;">
    <div class="sidebar-top">
        <div class="sidebar-profile">
            <i class="fa-solid fa-user"></i>
            <div class="profile-info">
                <div class="profile-text">Mr</div>
                <div class="profile-text">Jodi Cunningham</div>
            </div>
        </div>
        <div class="profile-role">
            Laboratory Manager
        </div>
    </div>

    <div class="sidebar-bottom" style="overflow-y:auto;flex:1;">
        <div style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; color: #adb5bd; margin-top: 0.5rem;">
            Management
        </div>
        <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="sidebar-link">
            <span style="color:#6f42c1">●</span> Test Categories
        </a>
        <a asp-controller="LabManager" asp-action="TestTypeIndex" class="sidebar-link">
            <span style="color:#0d6efd">●</span> Test Types
        </a>
        <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="sidebar-link">
            <span style="color:#0dcaf0">●</span> Sample Types
        </a>
        <a asp-controller="LabManager" asp-action="ConsumableIndex" class="sidebar-link">
            <span style="color:#dc3545">●</span> Consumables
        </a>
        <a asp-controller="LabManager" asp-action="SupplierIndex" class="sidebar-link">
            <span style="color:#fd7e14">●</span> Suppliers
        </a>
        <a asp-controller="LabManager" asp-action="DoctorIndex" class="sidebar-link">
            <span style="color:#198754">●</span> Doctors
        </a>
        <a asp-controller="LabManager" asp-action="TechnicianIndex" class="sidebar-link">
            <span style="color:#6610f2">●</span> Technicians
        </a>
        <a asp-controller="LabManager" asp-action="OrderIndex" class="sidebar-link">
            <span style="color:#e8590c">●</span> Orders
        </a>

        <div class="sidebar-actions">
            <a href="#"
               class="sidebar-alert-btn ajax-link"
               data-url="@Url.Action("UpdateProfile", "Admin")">
                <i class="fa-solid fa-user-gear"></i>
                Profile Settings
            </a>
            <a asp-controller="Account" asp-action="Logout" class="sidebar-primary-btn">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        </div>
    </div>
</div>
    <div class="main-content">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4 border-cons">
                <div>
                    <h2 class="h4 mb-0">Consumables</h2>
                    <small class="text-muted">Inventory management and stock level adjustments</small>
                </div>
                <button class="btn btn-cons" data-bs-toggle="collapse" data-bs-target="#addConsumable"><i class="fa-solid fa-plus me-2"></i>Add Consumable</button>
            </div>

            <div class="collapse mb-4" id="addConsumable">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <form asp-controller="LabManager" asp-action="ConsumableCreate" method="post" class="row g-3">
                            <div class="col-md-4"><label class="form-label fw-semibold">Consumable Name <span class="text-danger">*</span></label><input type="text" name="ConsumableName" class="form-control" required /></div>
                            <div class="col-md-4"><label class="form-label fw-semibold">Supplier <span class="text-danger">*</span></label><select name="SupplierId" class="form-select" required><option value="">Select...</option><option value="1">MedSupply SA</option><option value="2">LabWare Pty</option></select></div>
                            <div class="col-md-2"><label class="form-label fw-semibold">Reorder Level</label><input type="number" name="ReorderLevel" class="form-control" value="10" /></div>
                            <div class="col-md-2"><label class="form-label fw-semibold">Qty On Hand</label><input type="number" name="QuantityOnHand" class="form-control" value="0" /></div>
                            <div class="col-12"><button type="submit" class="btn btn-cons">Save Consumable</button></div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0 table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-cons"><tr><th>Consumable</th><th>Supplier</th><th>Reorder Level</th><th>Qty On Hand</th><th>Status</th><th class="text-end" style="width:220px">Adjust Stock</th></tr></thead>
                        <tbody>
                            <tr class="stock-low">
                                <td>EDTA Tube (4ml)</td>
                                <td>MedSupply SA</td>
                                <td>50</td>
                                <td>5</td>
                                <td><span class="badge bg-danger">Below Reorder</span></td>
                                <td class="text-end">
                                    <form method="post" asp-controller="LabManager" asp-action="AdjustStock" class="d-inline-flex gap-1"><input type="hidden" name="ConsumableId" value="1" /><input type="number" name="Amount" class="form-control form-control-sm" style="width:60px" placeholder="Qty" /><button type="submit" name="Action" value="Increase" class="btn btn-sm btn-success">+</button><button type="submit" name="Action" value="Decrease" class="btn btn-sm btn-warning">–</button><button type="submit" name="Action" value="Set" class="btn btn-sm btn-secondary">Set</button></form>
                                </td>
                            </tr>
                            <tr>
                                <td>Citrate Tube (3ml)</td>
                                <td>MedSupply SA</td>
                                <td>40</td>
                                <td>120</td>
                                <td><span class="badge bg-success">OK</span></td>
                                <td class="text-end">
                                    <form method="post" asp-controller="LabManager" asp-action="AdjustStock" class="d-inline-flex gap-1"><input type="hidden" name="ConsumableId" value="2" /><input type="number" name="Amount" class="form-control form-control-sm" style="width:60px" placeholder="Qty" /><button type="submit" name="Action" value="Increase" class="btn btn-sm btn-success">+</button><button type="submit" name="Action" value="Decrease" class="btn btn-sm btn-warning">–</button><button type="submit" name="Action" value="Set" class="btn btn-sm btn-secondary">Set</button></form>
                                </td>
                            </tr>
                            <tr class="stock-low">
                                <td>Reagent A</td>
                                <td>LabWare Pty</td>
                                <td>20</td>
                                <td>18</td>
                                <td><span class="badge bg-warning text-dark">Near Reorder</span></td>
                                <td class="text-end">
                                    <form method="post" asp-controller="LabManager" asp-action="AdjustStock" class="d-inline-flex gap-1"><input type="hidden" name="ConsumableId" value="3" /><input type="number" name="Amount" class="form-control form-control-sm" style="width:60px" placeholder="Qty" /><button type="submit" name="Action" value="Increase" class="btn btn-sm btn-success">+</button><button type="submit" name="Action" value="Decrease" class="btn btn-sm btn-warning">–</button><button type="submit" name="Action" value="Set" class="btn btn-sm btn-secondary">Set</button></form>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
