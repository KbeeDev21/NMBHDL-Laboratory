@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Doctors</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
    <style>
        .main-content {
            padding: 2rem;
        }

        .border-doc {
            border-left: 4px solid #198754;
            padding-left: 1rem;
        }

        .btn-doc {
            background-color: #198754;
            border-color: #198754;
            color: #fff;
        }

            .btn-doc:hover {
                background-color: #157347;
                border-color: #157347;
                color: #fff;
            }

        .text-doc {
            color: #198754;
        }

        .bg-doc {
            background-color: #198754;
            color: #fff;
        }

        .table thead th {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>
    <!-- SIDEBAR -->
    <div class="sidebar" style="display:flex;flex-direction:column;height:100vh;">
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>
                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Jodi Cunningham</div>
                </div>
            </div>
            <div class="profile-role">
                Laboratory Manager
            </div>
        </div>

        <div class="sidebar-bottom" style="overflow-y:auto;flex:1;">
            <div style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; color: #adb5bd; margin-top: 0.5rem;">
                Management
            </div>
            <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="sidebar-link">
                <span style="color:#6f42c1">●</span> Test Categories
            </a>
            <a asp-controller="LabManager" asp-action="TestTypeIndex" class="sidebar-link">
                <span style="color:#0d6efd">●</span> Test Types
            </a>
            <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="sidebar-link">
                <span style="color:#0dcaf0">●</span> Sample Types
            </a>
            <a asp-controller="LabManager" asp-action="ConsumableIndex" class="sidebar-link">
                <span style="color:#dc3545">●</span> Consumables
            </a>
            <a asp-controller="LabManager" asp-action="SupplierIndex" class="sidebar-link">
                <span style="color:#fd7e14">●</span> Suppliers
            </a>
            <a asp-controller="LabManager" asp-action="DoctorIndex" class="sidebar-link">
                <span style="color:#198754">●</span> Doctors
            </a>
            <a asp-controller="LabManager" asp-action="TechnicianIndex" class="sidebar-link">
                <span style="color:#6610f2">●</span> Technicians
            </a>
            <a asp-controller="LabManager" asp-action="OrderIndex" class="sidebar-link">
                <span style="color:#e8590c">●</span> Orders
            </a>

            <div class="sidebar-actions">
                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">
                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4 border-doc">
                <div>
                    <h2 class="h4 mb-0">Doctors</h2>
                    <small class="text-muted">Manage doctor accounts and HPCSA credentials</small>
                </div>
                <a asp-controller="LabManager" asp-action="DoctorCreate" class="btn btn-doc"><i class="fa-solid fa-plus me-2"></i>Add Doctor</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0 table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-doc"><tr><th>Name</th><th>Surname</th><th>HPCSA No</th><th>Email</th><th>Contact</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                        <tbody>
                            <tr><td>Dr Sarah</td><td>Venter</td><td>MP0123456</td><td>sarah.venter@clinic.co.za</td><td>082 123 4567</td><td><span class="badge bg-warning text-dark">Must Change Password</span></td><td class="text-end"><button class="btn btn-sm btn-outline-light text-white border-white"><i class="fa-solid fa-pen-to-square"></i></button> <button class="btn btn-sm btn-outline-light text-white border-white"><i class="fa-solid fa-trash"></i></button></td></tr>
                            <tr><td>Dr James</td><td>Nkosi</td><td>MP0654321</td><td>j.nkosi@doctor.co.za</td><td>083 987 6543</td><td><span class="badge bg-success">Active</span></td><td class="text-end"><button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-pen-to-square"></i></button> <button class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-trash"></i></button></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
