@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Patient Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">

        
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>

                <div class="profile-info">
                    <div class="profile-text">Mrs</div>
                    <div class="profile-text">Lindiwe Mhlongo</div>
                </div>
            </div>

            <div class="profile-role">
                Patient
            </div>

        </div>

       
        
        <div class="sidebar-bottom">

            <!-- VIEW TEST REQUESTS & RESULTS -->
            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("ViewTestRequests", "Patient")">

                <i class="fa-solid fa-flask"></i>

                View Test Requests & Results

            </a>

            <!-- MEDICAL HISTORY -->
            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("MedicalHistory", "Patient")">

                <i class="fa-solid fa-file-medical"></i>

                Medical History

            </a>

            <!-- CONSENT MANAGEMENT -->
            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("ConsentManagement", "Patient")">

                <i class="fa-solid fa-lock"></i>

                Consent Management

            </a>

            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("TrackTestResults", "Patient")">

                <i class="fa-solid fa-hourglass"></i>

                Track Test Results

            </a>

            <!-- REPORTS -->
            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("PatientReports", "Patient")">

                <i class="fa-solid fa-chart-line"></i>

                Reports

            </a>

            <div class="sidebar-actions">

                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">

                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings

                </a>

                <a asp-controller="" asp-action="" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>

            </div>

        </div>

    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content d-flex align-items-center justify-content-center vh-100" id="mainContent">

        <div class="text-center">

            <h1 class="display-5 fw-semibold mb-2"
                style="letter-spacing: 0.5px;">

                Welcome to Patient Dashboard

            </h1>

            

        </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        let trendChartInstance = null;

        function loadTrendChart() {

        const canvas = document.getElementById("trendChart");
        if (!canvas) return;

        const ctx = canvas.getContext("2d");

        // Destroy previous chart if it exists (prevents duplicates)
        if (trendChartInstance) {
        trendChartInstance.destroy();
        }

        // Predefined demo datasets
        const datasets = {

        cholesterol: [4.8, 5.1, 5.3, 5.0, 5.6, 5.4, 5.8, 5.5],
        glucose: [4.2, 4.5, 4.1, 4.8, 5.0, 4.9, 5.2, 5.1],
        haemoglobin: [13.1, 13.5, 13.8, 14.0, 13.7, 13.9, 14.2, 14.0]

        };

        const labels = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug"];

        const selected = document.getElementById("testTypeSelect")?.value || "cholesterol";

        trendChartInstance = new Chart(ctx, {

        type: 'line',

        data: {

        labels: labels,

        datasets: [{

        label: selected.toUpperCase() + " Trend",

        data: datasets[selected],

        borderColor: "#0d6efd",
        backgroundColor: "rgba(13,110,253,0.1)",
        fill: true,
        tension: 0.4,
        pointRadius: 5

        }]

        },

        options: {

        responsive: true,
        maintainAspectRatio: false,

        plugins: {
        legend: {
        display: true
        }
        },

        scales: {
        y: {
        beginAtZero: false
        }
        }

        }

        });

        }

        // Auto-load after AJAX inject
        function initTrendView() {
        setTimeout(loadTrendChart, 100);
        }

    </script>
    <!-- AJAX CONTENT LOADER -->
    <script>

                

        document.addEventListener("click", function (e) {

        const link = e.target.closest(".ajax-link");

        if (!link) return;

        e.preventDefault();

        const url = link.dataset.url;

        fetch(url)
        .then(res => res.text())
        .then(html => {

        document.getElementById("mainContent").innerHTML = html;

        });

        });

    </script>
    

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
