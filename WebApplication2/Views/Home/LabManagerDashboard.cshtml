@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Lab Manager Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />

    <style>
        .dashboard-wrapper {
            padding: 2rem;
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .page-title {
            font-weight: 600;
            letter-spacing: 0.5px;
            margin-bottom: 0.25rem;
        }

        .page-subtitle {
            color: #6c757d;
            margin-bottom: 2rem;
        }

        .dash-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 1rem;
            padding: 2rem 1.25rem;
            height: 100%;
            text-decoration: none;
            color: #212529;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        }

            .dash-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
                border-color: #adb5bd;
                color: #212529;
            }

        .dash-icon-wrap {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #fff;
            margin-bottom: 1rem;
            box-shadow: 0 0.25rem 0.5rem rgba(0,0,0,0.1);
        }

        .dash-title {
            font-weight: 600;
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }

        .dash-desc {
            font-size: 0.875rem;
            color: #6c757d;
            line-height: 1.4;
            margin-bottom: 0;
        }
        /* Colour coding per module */
        .bg-cat {
            background: #6f42c1;
        }

        .bg-type {
            background: #0d6efd;
        }

        .bg-sample {
            background: #0dcaf0;
            color: #000 !important;
        }

        .bg-cons {
            background: #dc3545;
        }

        .bg-supp {
            background: #fd7e14;
        }

        .bg-doc {
            background: #198754;
        }

        .bg-tech {
            background: #6610f2;
        }

        .bg-order {
            background: #e8590c;
        }
        /* Sidebar scroll */
        .sidebar {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        .sidebar-bottom {
            overflow-y: auto;
            flex: 1;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar" style="display:flex;flex-direction:column;height:100vh;">
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>
                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Jodi Cunningham</div>
                </div>
            </div>
            <div class="profile-role">
                Laboratory Manager
            </div>
        </div>

        <div class="sidebar-bottom" style="overflow-y:auto;flex:1;">
            <div style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; color: #adb5bd; margin-top: 0.5rem;">
                Management
            </div>
            <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="sidebar-link">
                <span style="color:#6f42c1">●</span> Test Categories
            </a>
            <a asp-controller="LabManager" asp-action="TestTypeIndex" class="sidebar-link">
                <span style="color:#0d6efd">●</span> Test Types
            </a>
            <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="sidebar-link">
                <span style="color:#0dcaf0">●</span> Sample Types
            </a>
            <a asp-controller="LabManager" asp-action="ConsumableIndex" class="sidebar-link">
                <span style="color:#dc3545">●</span> Consumables
            </a>
            <a asp-controller="LabManager" asp-action="SupplierIndex" class="sidebar-link">
                <span style="color:#fd7e14">●</span> Suppliers
            </a>
            <a asp-controller="LabManager" asp-action="DoctorIndex" class="sidebar-link">
                <span style="color:#198754">●</span> Doctors
            </a>
            <a asp-controller="LabManager" asp-action="TechnicianIndex" class="sidebar-link">
                <span style="color:#6610f2">●</span> Technicians
            </a>
            <a asp-controller="LabManager" asp-action="OrderIndex" class="sidebar-link">
                <span style="color:#e8590c">●</span> Orders
            </a>

            <div class="sidebar-actions">
                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">
                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content" id="mainContent">
        <div class="dashboard-wrapper">

            <!-- Header -->
            <div class="mb-4">
                <h1 class="page-title display-6">Welcome, Mr Cunningham</h1>
                <p class="page-subtitle">Laboratory Management Dashboard — select a module below to begin.</p>
            </div>

            <!-- Management Module Cards -->
            <div class="row g-4">

                <!-- 1. Test Categories -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="LabManager" asp-action="TestCategoryIndex" class="dash-card">
                        <div class="dash-icon-wrap bg-cat">
                            <i class="fa-solid fa-folder-tree"></i>
                        </div>
                        <div class="dash-title">Test Categories</div>
                        <p class="dash-desc">Create and manage test category records and descriptions.</p>
                    </a>
                </div>

                <!-- 2. Test Types -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="LabManager" asp-action="TestTypeIndex" class="dash-card">
                        <div class="dash-icon-wrap bg-type">
                            <i class="fa-solid fa-flask-vial"></i>
                        </div>
                        <div class="dash-title">Test Types</div>
                        <p class="dash-desc">Configure test definitions, normal ranges, turnaround times and linked consumables.</p>
                    </a>
                </div>

                <!-- 3. Sample Types -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="LabManager" asp-action="SampleTypeIndex" class="dash-card">
                        <div class="dash-icon-wrap bg-sample">
                            <i class="fa-solid fa-vial"></i>
                        </div>
                        <div class="dash-title">Sample Types</div>
                        <p class="dash-desc">Manage sample type definitions (whole blood, plasma, bone marrow, etc.).</p>
                    </a>
                </div>

                <!-- 4. Consumables -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="LabManager" asp-action="ConsumableIndex" class="dash-card">
                        <div class="dash-icon-wrap bg-cons">
                            <i class="fa-solid fa-boxes-stacked"></i>
                        </div>
                        <div class="dash-title">Consumables</div>
                        <p class="dash-desc">Track consumable inventory, stock levels, reorder points and adjust quantities.</p>
                    </a>
                </div>

                <!-- 5. Suppliers -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="LabManager" asp-action="SupplierIndex" class="dash-card">
                        <div class="dash-icon-wrap bg-supp">
                            <i class="fa-solid fa-truck-field"></i>
                        </div>
                        <div class="dash-title">Suppliers</div>
                        <p class="dash-desc">Maintain supplier records, contacts and manage consumable orders.</p>
                    </a>
                </div>

                <!-- 6. Doctors -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="LabManager" asp-action="DoctorIndex" class="dash-card">
                        <div class="dash-icon-wrap bg-doc">
                            <i class="fa-solid fa-user-doctor"></i>
                        </div>
                        <div class="dash-title">Doctors</div>
                        <p class="dash-desc">Register and manage doctor user accounts and HPCSA credentials.</p>
                    </a>
                </div>

                <!-- 7. Technicians -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="LabManager" asp-action="TechnicianIndex" class="dash-card">
                        <div class="dash-icon-wrap bg-tech">
                            <i class="fa-solid fa-user-gear"></i>
                        </div>
                        <div class="dash-title">Technicians</div>
                        <p class="dash-desc">Manage lab technician profiles, assignments and test-type capabilities.</p>
                    </a>
                </div>

                <!-- 8. Consumable Orders -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <a asp-controller="LabManager" asp-action="OrderIndex" class="dash-card">
                        <div class="dash-icon-wrap bg-order">
                            <i class="fa-solid fa-cart-shopping"></i>
                        </div>
                        <div class="dash-title">Orders</div>
                        <p class="dash-desc">Create stock orders, track fulfilment status and receive consumables.</p>
                    </a>
                </div>

            </div>

        </div>
    </div>

    <!-- AJAX loader kept for existing sidebar links -->
    <script>
        function loadSection(section) {
            fetch('/Home/LoadDashboardSection?section=' + section)
                .then(res => res.text())
                .then(html => {
                    document.getElementById("mainContent").innerHTML = html;
                });
        }
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>