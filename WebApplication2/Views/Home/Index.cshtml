@{
    ViewData["Title"] = "Home Page";
}

<!-- HERO SECTION -->
<section id="hero" class="hero-section d-flex align-items-center justify-content-center text-center position-relative">

    <!-- overlay -->
    <div class="hero-overlay"></div>

    <div class="container position-relative text-white">

        <h1 class="display-4 fw-bold">
            Welcome <br />
            To <br />
            NMBHDL Laboratory
        </h1>

        <p class="fs-5 mt-3">
            Accurate diagnostics. Reliable results. Better healthcare.
        </p>

        <a href="#about" class="btn btn-light mt-3 px-4">
            Learn More
        </a>

    </div>

</section>

<!-- ABOUT SECTION -->
<section id="about" class="py-5">

    <div class="container text-center">

        <h2 class="fw-bold mb-3">About Us</h2>

        <p class="text-muted mx-auto" style="max-width:700px;">
            We are a modern haematology laboratory providing accurate,
            fast and reliable diagnostic testing services for healthcare providers.
            Our system ensures efficiency, traceability and patient safety.
        </p>

    </div>

</section>

<!-- SERVICES SECTION -->
<section id="services" class="py-5 bg-light">

    <div class="container text-center">

        <h2 class="fw-bold mb-4">Services</h2>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-4 h-100">
                    <h5 class="fw-semibold">Full Blood Count</h5>
                    <p class="text-muted">Comprehensive blood analysis</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-4 h-100">
                    <h5 class="fw-semibold">Coagulation Tests</h5>
                    <p class="text-muted">Clotting and bleeding assessment</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 p-4 h-100">
                    <h5 class="fw-semibold">Disease Screening</h5>
                    <p class="text-muted">Early detection of conditions</p>
                </div>
            </div>

        </div>

    </div>

</section>

<!-- TESTIMONIALS SECTION -->
<section id="testimonials" class="py-5">

    <div class="container text-center">

        <h2 class="fw-bold mb-4">Testimonials</h2>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="p-4 shadow-sm border rounded h-100">
                    <p class="text-muted">
                        “Excellent service and fast results.”
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 shadow-sm border rounded h-100">
                    <p class="text-muted">
                        “Very professional laboratory staff.”
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 shadow-sm border rounded h-100">
                    <p class="text-muted">
                        “Reliable and accurate testing every time.”
                    </p>
                </div>
            </div>

        </div>

    </div>

</section>