@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Admin Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">

        
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>

                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Karabo Modau</div>
                </div>
            </div>

            <div class="profile-role">
                Administrator
            </div>

        </div>

       
        
        <div class="sidebar-bottom">
          
            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("ListMedicalConditions", "Admin")">
                <i class="fa-solid fa-virus"></i> Medical Conditions
            </a>

            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("ListAllergies", "Admin")">
                <i class="fa-solid fa-hand-dots"></i> Allergies
            </a>

            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("ListMedication", "Admin")">
                <i class="fa-solid fa-capsules"></i> Medication
            </a>

            

            <div class="sidebar-actions">

                <a href="#"
                   class="sidebar-alert-btn ajax-link"
                   data-url="@Url.Action("UpdateProfile", "Admin")">

                    <i class="fa-solid fa-user-gear"></i>
                    Profile Settings

                </a>

                <a asp-controller="" asp-action="" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>

            </div>

        </div>

    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content d-flex align-items-center justify-content-center vh-100" id="mainContent">

        <div class="text-center">

            <h1 class="display-5 fw-semibold mb-2"
                style="letter-spacing: 0.5px;">

                Welcome to Admin Dashboard

            </h1>

            

        </div>

    </div>
    <!-- AJAX CONTENT LOADER -->
    <script>

                

            document.addEventListener("click", function (e) {

                const link = e.target.closest(".ajax-link");

                if (!link) return;

                e.preventDefault();

                const url = link.dataset.url;

                fetch(url)
                    .then(res => res.text())
                    .then(html => {

                        document.getElementById("mainContent").innerHTML = html;

                    });

            });

    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>