@{
    Layout = null;
}

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">

        <div>

            <h3 class="mb-1 fw-semibold">
                Patient Reports
            </h3>

            <small class="text-muted">
                Generate downloadable PDF reports for your test results
            </small>

        </div>

        <span class="badge bg-danger-subtle text-danger px-3 py-2">
            PDF Export
        </span>

    </div>

    <!-- Date Range + Actions -->
    <div class="card border-0 shadow-sm mb-4">

        <div class="card-body">

            <div class="row g-3 align-items-end">

                <!-- From -->
                <div class="col-md-4">

                    <label class="form-label fw-medium">From Date</label>

                    <input type="date" class="form-control form-control-lg" />

                </div>

                <!-- To -->
                <div class="col-md-4">

                    <label class="form-label fw-medium">To Date</label>

                    <input type="date" class="form-control form-control-lg" />

                </div>

                <!-- Button -->
                <div class="col-md-4 d-flex gap-2">

                    <button class="btn btn-primary btn-lg w-100">

                        <i class="fa-solid fa-file-pdf me-2"></i>
                        Generate PDF

                    </button>

                    <button class="btn btn-light border btn-lg">

                        <i class="fa-solid fa-eye me-2"></i>
                        Preview

                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- Report Preview (Skeleton Grouped View) -->
    <div class="card border-0 shadow-sm">

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <div>

                    <h5 class="fw-semibold mb-1">
                        Report Preview
                    </h5>

                    <small class="text-muted">
                        Results grouped by test category
                    </small>

                </div>

                <span class="badge bg-success-subtle text-success px-3 py-2">
                    Ready for Export
                </span>

            </div>

            <!-- CATEGORY: Haematology -->
            <div class="mb-4">

                <h6 class="fw-bold text-primary mb-3">
                    Haematology
                </h6>

                <div class="table-responsive">

                    <table class="table table-sm align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>Test</th>
                                <th>Result</th>
                                <th>Unit</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>

                        </thead>

                        <tbody>

                            <tr>
                                <td>Haemoglobin</td>
                                <td>13.8</td>
                                <td>g/dL</td>
                                <td>10 May 2026</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success">
                                        Normal
                                    </span>
                                </td>
                            </tr>

                            <tr>
                                <td>WBC</td>
                                <td>6.2</td>
                                <td>x10³/µL</td>
                                <td>10 May 2026</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success">
                                        Normal
                                    </span>
                                </td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

            <!-- CATEGORY: Biochemistry -->
            <div class="mb-4">

                <h6 class="fw-bold text-primary mb-3">
                    Biochemistry
                </h6>

                <div class="table-responsive">

                    <table class="table table-sm align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>Test</th>
                                <th>Result</th>
                                <th>Unit</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>

                        </thead>

                        <tbody>

                            <tr>
                                <td>Cholesterol</td>
                                <td>5.4</td>
                                <td>mmol/L</td>
                                <td>08 May 2026</td>
                                <td>
                                    <span class="badge bg-warning-subtle text-warning">
                                        Borderline
                                    </span>
                                </td>
                            </tr>

                            <tr>
                                <td>Glucose</td>
                                <td>4.9</td>
                                <td>mmol/L</td>
                                <td>08 May 2026</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success">
                                        Normal
                                    </span>
                                </td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>