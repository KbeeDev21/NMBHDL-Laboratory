@{
    Layout = null;
}

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">

        <div>

            <h3 class="mb-1 fw-semibold">
                Consent Management
            </h3>

            <small class="text-muted">
                Control which doctors can access your test results
                and manage data permissions
            </small>

        </div>

        <span class="badge bg-primary-subtle text-primary px-3 py-2">
            Privacy & Access Control
        </span>

    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">

        <!-- Active Consents -->
        <div class="col-md-4">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted d-block mb-1">
                                Active Consents
                            </small>

                            <h4 class="fw-bold mb-0">
                                2
                            </h4>

                        </div>

                        <div class="icon-circle bg-success-subtle text-success">

                            <i class="fa-solid fa-lock-open fs-5"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Pending Requests -->
        <div class="col-md-4">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted d-block mb-1">
                                Pending Requests
                            </small>

                            <h4 class="fw-bold mb-0">
                                1
                            </h4>

                        </div>

                        <div class="icon-circle bg-warning-subtle text-warning">

                            <i class="fa-solid fa-hourglass-half fs-5"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Revoked Access -->
        <div class="col-md-4">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted d-block mb-1">
                                Revoked Access
                            </small>

                            <h4 class="fw-bold mb-0">
                                0
                            </h4>

                        </div>

                        <div class="icon-circle bg-danger-subtle text-danger">

                            <i class="fa-solid fa-lock fs-5"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Main Card -->
    <div class="card border-0 shadow-sm">

        <div class="card-body">

            <!-- Header Actions -->
            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>

                    <h5 class="fw-semibold mb-1">
                        Doctor Access Control
                    </h5>

                    <small class="text-muted">
                        Grant or revoke access to your medical records
                    </small>

                </div>

                <button class="btn btn-primary">

                    <i class="fa-solid fa-plus me-2"></i>

                    Grant Access

                </button>

            </div>

            <!-- Table -->
            <div class="table-responsive">

                <table class="table align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Doctor</th>
                            <th>Access Level</th>
                            <th>Granted Date</th>
                            <th>Test Requests Shared</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        <!-- Row 1 -->
                        <tr>

                            <td class="fw-medium">
                                Dr. Daniels
                            </td>

                            <td>
                                Full Access
                            </td>

                            <td>
                                10 May 2026
                            </td>

                            <td>
                                5 Requests
                            </td>

                            <td>

                                <span class="badge bg-success-subtle text-success px-3 py-2">
                                    Active
                                </span>

                            </td>

                            <td class="text-end">

                                <div class="d-flex justify-content-end gap-2">

                                    <button class="btn btn-light border">

                                        <i class="fa-solid fa-eye"></i>

                                    </button>

                                    <button class="btn btn-danger">

                                        <i class="fa-solid fa-ban me-1"></i>

                                        Revoke

                                    </button>

                                </div>

                            </td>

                        </tr>

                        <!-- Row 2 -->
                        <tr>

                            <td class="fw-medium">
                                Dr. Jacobs
                            </td>

                            <td>
                                Limited Access
                            </td>

                            <td>
                                02 May 2026
                            </td>

                            <td>
                                2 Requests
                            </td>

                            <td>

                                <span class="badge bg-warning-subtle text-warning px-3 py-2">
                                    Pending
                                </span>

                            </td>

                            <td class="text-end">

                                <div class="d-flex justify-content-end gap-2">

                                    <button class="btn btn-success">

                                        <i class="fa-solid fa-check me-1"></i>

                                        Approve

                                    </button>

                                    <button class="btn btn-danger">

                                        <i class="fa-solid fa-xmark me-1"></i>

                                        Reject

                                    </button>

                                </div>

                            </td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<style>

    .icon-circle {
        width: 55px;
        height: 55px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

</style>