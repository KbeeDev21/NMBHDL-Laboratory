    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@{
    Layout = null;
}

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">

        <div>
            <h4 class="fw-semibold mb-1">Medication Inventory</h4>
            <small class="text-muted">
                View prescribed medication records and monitor stock levels
            </small>
        </div>

        <a href="#"
           class="btn btn-outline-success ajax-link"
           data-url="@Url.Action("AddMedication", "Admin")">

            <i class="fa-solid fa-plus me-1"></i>
            Add Medication

        </a>

    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th class="px-4 py-3">Medication</th>
                            <th class="py-3">Category</th>
                            <th class="py-3">Dosage Form</th>
                            <th class="py-3">Strength</th>
                            <th class="py-3">Prescription</th>
                            <th class="py-3">Quantity</th>
                            <th class="py-3">Stock Status</th>
                            <th class="py-3">Side Effects</th>
                            <th class="py-3 text-center">Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        <!-- Row -->
                        <tr>

                            <td class="px-4 fw-semibold">
                                Amoxicillin
                            </td>

                            <td>
                                <span class="badge bg-primary-subtle text-primary px-3 py-2">
                                    Antibiotic
                                </span>
                            </td>

                            <td>
                                Capsule
                            </td>

                            <td>
                                500 mg
                            </td>

                            <td>
                                <span class="badge bg-warning-subtle text-warning px-3 py-2">
                                    Required
                                </span>
                            </td>

                            <td>
                                120 Units
                            </td>

                            <td>
                                <span class="badge bg-success-subtle text-success px-3 py-2">
                                    In Stock
                                </span>
                            </td>

                            <td class="text-muted">
                                Nausea and mild dizziness
                            </td>

                            <td class="text-center">

                                <button class="btn btn-sm btn-light border me-1">
                                    Edit
                                </button>

                                <button class="btn btn-sm btn-danger">
                                    Delete
                                </button>

                            </td>

                        </tr>

                        <!-- Row -->
                        <tr>

                            <td class="px-4 fw-semibold">
                                Insulin
                            </td>

                            <td>
                                <span class="badge bg-success-subtle text-success px-3 py-2">
                                    Antidiabetic
                                </span>
                            </td>

                            <td>
                                Injection
                            </td>

                            <td>
                                10 ml
                            </td>

                            <td>
                                <span class="badge bg-warning-subtle text-warning px-3 py-2">
                                    Required
                                </span>
                            </td>

                            <td>
                                8 Units
                            </td>

                            <td>
                                <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                    Low Stock
                                </span>
                            </td>

                            <td class="text-muted">
                                Risk of hypoglycemia
                            </td>

                            <td class="text-center">

                                <button class="btn btn-sm btn-light border me-1">
                                    Edit
                                </button>

                                <button class="btn btn-sm btn-danger">
                                    Delete
                                </button>

                            </td>

                        </tr>

                        <!-- Empty State -->
                        <!--
                        <tr>
                            <td colspan="9" class="text-center py-5">

                                <div class="text-muted">

                                    <i class="fa-solid fa-capsules fs-1 d-block mb-3"></i>

                                    No medication records available.

                                </div>

                            </td>
                        </tr>
                        -->

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>