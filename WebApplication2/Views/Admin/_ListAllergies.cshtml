@{
    Layout = null;
}

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">

        <div>
            <h4 class="fw-semibold mb-1">Recorded Allergies</h4>
            <small class="text-muted">
                View all saved patient allergies and emergency risks
            </small>
        </div>

        <a href="#"
           class="btn btn-outline-danger ajax-link"
           data-url="@Url.Action("AddAllergies", "Admin")">

            <i class="fa-solid fa-plus me-1"></i>
            Add New Allergy

        </a>

    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th class="px-4 py-3">Allergy</th>
                            <th class="py-3">Category</th>
                            <th class="py-3">Reaction</th>
                            <th class="py-3">Severity</th>
                            <th class="py-3">Emergency</th>
                            <th class="py-3">Clinical Notes</th>
                            <th class="py-3 text-center">Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        <!-- Row -->
                        <tr>

                            <td class="px-4 fw-semibold">
                                Peanuts
                            </td>

                            <td>
                                <span class="badge bg-warning-subtle text-warning px-3 py-2">
                                    Food
                                </span>
                            </td>

                            <td class="text-muted">
                                Swelling and skin rash
                            </td>

                            <td>
                                <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                    Severe
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                    Yes
                                </span>
                            </td>

                            <td class="text-muted">
                                Patient carries emergency epinephrine injector.
                            </td>

                            <td class="text-center">

                                <button class="btn btn-sm btn-light border me-1">
                                    Edit
                                </button>

                                <button class="btn btn-sm btn-danger">
                                    Delete
                                </button>

                            </td>

                        </tr>

                        <!-- Row -->
                        <tr>

                            <td class="px-4 fw-semibold">
                                Penicillin
                            </td>

                            <td>
                                <span class="badge bg-info-subtle text-info px-3 py-2">
                                    Drug
                                </span>
                            </td>

                            <td class="text-muted">
                                Breathing difficulty
                            </td>

                            <td>
                                <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                    Anaphylactic
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                    Yes
                                </span>
                            </td>

                            <td class="text-muted">
                                Avoid all penicillin-based medication.
                            </td>

                            <td class="text-center">

                                <button class="btn btn-sm btn-light border me-1">
                                    Edit
                                </button>

                                <button class="btn btn-sm btn-danger">
                                    Delete
                                </button>

                            </td>

                        </tr>

                        <!-- Empty State -->
                        <!--
                        <tr>
                            <td colspan="7" class="text-center py-5">

                                <div class="text-muted">

                                    <i class="fa-solid fa-triangle-exclamation fs-1 d-block mb-3"></i>

                                    No allergies recorded yet.

                                </div>

                            </td>
                        </tr>
                        -->

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>