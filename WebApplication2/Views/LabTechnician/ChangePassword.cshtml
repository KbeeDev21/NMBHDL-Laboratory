@{
    Layout = "~/Views/Shared/_LabTechLayout.cshtml";
    ViewData["Title"] = "Change Password";
}

<style>
    body {
        background-color: #071D37 !important;
        color: white !important;
    }

    .page-container {
        max-width: 700px;
        margin: 50px auto;
    }

    .card-dark {
        background: #102B4E;
        border-radius: 20px;
        padding: 35px;
        border: 1px solid #1B3E68;
    }

    .form-control,
    .form-control:focus {
        background: #0B2447;
        color: white;
        border: 1px solid #355C8A;
        box-shadow: none;
    }

    .btn-dark-custom {
        background: #163A63;
        border: 1px solid #355C8A;
        color: white !important;
        border-radius: 12px;
        padding: 10px 18px;
        text-decoration: none;
        transition: 0.2s ease;
    }

        .btn-dark-custom:hover {
            background: #1B4B7A;
            border-color: #4d79a8;
        }

    .password-wrapper {
        position: relative;
    }

    .toggle-password {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #c5d3e0;
        font-size: 1rem;
        user-select: none;
    }

        .toggle-password:hover {
            color: white;
        }

    .text-muted {
        color: #c5d3e0 !important;
    }

    label {
        margin-bottom: 6px;
    }

    h1 {
        color: white;
        font-weight: 700;
    }
</style>

<div class="page-container">

    <div class="card-dark">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h1>Change Password</h1>

                <p class="text-muted">
                    Update your account password securely.
                </p>

            </div>

            <a asp-controller="LabTechnician"
               asp-action="Profile"
               class="btn-dark-custom">

                ← Profile

            </a>

        </div>

        <!-- Current Password -->
        <div class="mb-4">

            <label class="form-label">
                Current Password
            </label>

            <div class="password-wrapper">

                <input type="password"
                       id="currentPassword"
                       class="form-control" />

                <span class="toggle-password"
                      onclick="togglePassword('currentPassword', this)">

                    <i class="fa-solid fa-eye"></i>

                </span>

            </div>

        </div>

        <!-- New Password -->
        <div class="mb-4">

            <label class="form-label">
                New Password
            </label>

            <div class="password-wrapper">

                <input type="password"
                       id="newPassword"
                       class="form-control" />

                <span class="toggle-password"
                      onclick="togglePassword('newPassword', this)">

                    <i class="fa-solid fa-eye"></i>

                </span>

            </div>

        </div>

        <!-- Confirm Password -->
        <div class="mb-4">

            <label class="form-label">
                Confirm New Password
            </label>

            <div class="password-wrapper">

                <input type="password"
                       id="confirmPassword"
                       class="form-control" />

                <span class="toggle-password"
                      onclick="togglePassword('confirmPassword', this)">

                    <i class="fa-solid fa-eye"></i>

                </span>

            </div>

        </div>

        <!-- Actions -->
        <div class="mt-4">

            <button class="btn-dark-custom me-2">

                Update Password

            </button>

            <button class="btn-dark-custom">

                Clear

            </button>

        </div>

    </div>

</div>

<script>
    function togglePassword(fieldId, element) {

        const field = document.getElementById(fieldId);
        const icon = element.querySelector("i");

        if (field.type === "password") {
            field.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        }
        else {
            field.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }
</script>