@{
    Layout = "~/Views/Shared/_LabTechLayout.cshtml";
    ViewData["Title"] = "My Profile";
}

<style>
    body {
        background-color: #071D37 !important;
        color: white !important;
    }

    .page-container {
        max-width: 900px;
        margin: 50px auto;
    }

    .profile-card {
        background: #102B4E;
        border-radius: 20px;
        padding: 35px;
        border: 1px solid #1B3E68;
    }

    .profile-row {
        background: #163A63;
        border-radius: 14px;
        padding: 16px 20px;
        margin-bottom: 15px;
        border: 1px solid #1B3E68;
    }

    .profile-label {
        color: #c5d3e0;
        font-size: 0.9rem;
        margin-bottom: 4px;
    }

    .profile-value {
        font-size: 1.05rem;
        font-weight: 600;
        color: white;
    }

    .btn-dark-custom {
        background: #163A63;
        border: 1px solid #355C8A;
        color: white !important;
        border-radius: 12px;
        padding: 10px 20px;
        text-decoration: none;
        transition: 0.2s;
    }

        .btn-dark-custom:hover {
            background: #1B4B7A;
            border-color: #4d79a8;
        }

    h1 {
        font-weight: 700;
        color: white;
    }

    .text-muted {
        color: #c5d3e0 !important;
    }
</style>

<div class="page-container">

    <div class="profile-card">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h1>My Profile</h1>

                <p class="text-muted">
                    View and manage technician account information.
                </p>

            </div>

            <a asp-controller="Home"
               asp-action="LabTechnicianDashboard"
               class="btn-dark-custom">

                ← Dashboard

            </a>

        </div>

        <!-- Profile Details -->
        <div class="profile-row">

            <div class="profile-label">
                Full Name
            </div>

            <div class="profile-value">
                Thabo Mokoena
            </div>

        </div>

        <div class="profile-row">

            <div class="profile-label">
                Employee Number
            </div>

            <div class="profile-value">
                LT-001
            </div>

        </div>

        <div class="profile-row">

            <div class="profile-label">
                Email Address
            </div>

            <div class="profile-value">
                thabo.mokoena@nmbhlab.co.za
            </div>

        </div>

        <div class="profile-row">

            <div class="profile-label">
                Contact Number
            </div>

            <div class="profile-value">
                082 123 4567
            </div>

        </div>

        <div class="profile-row">

            <div class="profile-label">
                Role
            </div>

            <div class="profile-value">
                Laboratory Technician
            </div>

        </div>

        <!-- Actions -->
        <div class="mt-4">

            <a asp-controller="LabTechnician"
               asp-action="EditProfile"
               class="btn-dark-custom me-2">

                Edit Profile

            </a>

            <a asp-controller="LabTechnician"
               asp-action="ChangePassword"
               class="btn-dark-custom">

                Change Password

            </a>

        </div>

    </div>

</div>