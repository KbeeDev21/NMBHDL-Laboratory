@{    
    Layout = "~/Views/Shared/_LabTechLayout.cshtml";
    ViewData["Title"] = "Review Queue";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<link href="~/css/dashboardstyles.css" rel="stylesheet" />

<style>

    .page-container {
        padding: 0;
    }

    .card-dark {
        background: #102B4E;
        border-radius: 20px;
        padding: 30px;
        border: 1px solid #1B3E68;
    }

    .review-card {
        background: #163A63;
        border-radius: 16px;
        padding: 22px;
        margin-bottom: 20px;
        border-left: 4px solid #dc3545;
        border: 1px solid #1B3E68;
        transition: 0.2s ease;
    }

        .review-card:hover {
            background: #1B4B7A;
            transform: translateX(4px);
        }

    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        margin-right: 6px;
        margin-top: 5px;
        font-weight: 600;
    }

    .badge-review {
        background: #dc3545;
        color: white;
    }

    .badge-stat {
        background: #f4a261;
        color: black;
    }

    .badge-returned {
        background: #6c757d;
        color: white;
    }

    .note-box {
        background: #0B2447;
        border-radius: 12px;
        padding: 16px;
        margin-top: 15px;
        border-left: 4px solid #ffc107;
        border: 1px solid #355C8A;
    }

    .btn-dark-custom {
        background: #163A63;
        border: 1px solid #355C8A;
        color: white !important;
        border-radius: 12px;
        padding: 10px 18px;
        text-decoration: none;
        transition: 0.2s ease;
    }

        .btn-dark-custom:hover {
            background: #1B4B7A;
            border-color: #4d79a8;
        }

    .filter-box,
    .form-control,
    .form-select,
    .form-control:focus,
    .form-select:focus {
        background: #0B2447;
        color: white;
        border: 1px solid #355C8A;
        box-shadow: none;
    }

    .text-muted {
        color: #c5d3e0 !important;
    }

    h1,
    h4,
    p,
    strong {
        color: white;
    }

</style>


<!-- MAIN CONTENT -->
<div class="main-content">

    <div class="page-container">

        <div class="card-dark">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>

                    <h1>
                        Review Queue
                    </h1>

                    <p class="text-muted">
                        Tests returned after verification requiring technician review.
                    </p>

                </div>

                <a asp-controller="Home"
                   asp-action="LabTechnicianDashboard"
                   class="btn-dark-custom">

                    ← Dashboard

                </a>

            </div>

            <!-- Filters -->
            <div class="row g-3 mb-4">

                <div class="col-md-3">

                    <input class="form-control filter-box"
                           placeholder="Search request number..." />

                </div>

                <div class="col-md-3">

                    <select class="form-select filter-box">

                        <option>All Priorities</option>
                        <option>STAT</option>
                        <option>Routine</option>

                    </select>

                </div>

            </div>

            <!-- Review Item -->
            <div class="review-card">

                <div class="d-flex justify-content-between align-items-start">

                    <div>

                        <h4>
                            REQ-2026-00124
                        </h4>

                        <p class="mb-2">
                            <strong>Patient:</strong>
                            Baloyi, Thabo
                        </p>

                        <p class="mb-2">
                            <strong>Test:</strong>
                            Full Blood Count + Differential
                        </p>

                        <p class="mb-2">
                            <strong>Returned By:</strong>
                            Technician M. Jacobs
                        </p>

                        <span class="status-badge badge-review">
                            To Be Reviewed
                        </span>

                        <span class="status-badge badge-stat">
                            STAT
                        </span>

                        <span class="status-badge badge-returned">
                            Returned For Correction
                        </span>

                        <!-- Verification Note -->
                        <div class="note-box">

                            <strong>
                                Verification Note:
                            </strong>

                            <p class="mb-0 mt-2">
                                White Cell Count appears inconsistent with
                                previous patient history. Please confirm values.
                            </p>

                        </div>

                    </div>

                    <div class="text-end">

                        <p class="text-danger fw-bold">
                            Requires technician review
                        </p>

                        <a asp-controller="LabTechnician"
                           asp-action="CaptureResults"
                           class="btn-dark-custom me-2">

                            Review Result

                        </a>

                        <a asp-controller="LabTechnician"
                           asp-action="TestDetail"
                           class="btn-dark-custom">

                            View Detail

                        </a>

                    </div>

                </div>

            </div>

            <!-- Review Item -->
            <div class="review-card">

                <div class="d-flex justify-content-between align-items-start">

                    <div>

                        <h4>
                            REQ-2026-00131
                        </h4>

                        <p class="mb-2">
                            <strong>Patient:</strong>
                            Hendricks, Ayesha
                        </p>

                        <p class="mb-2">
                            <strong>Test:</strong>
                            PT / INR
                        </p>

                        <p class="mb-2">
                            <strong>Returned By:</strong>
                            Technician A. Smith
                        </p>

                        <span class="status-badge badge-review">
                            To Be Reviewed
                        </span>

                        <span class="status-badge badge-returned">
                            Returned For Correction
                        </span>

                        <div class="note-box">

                            <strong>
                                Verification Note:
                            </strong>

                            <p class="mb-0 mt-2">
                                INR result formatting incorrect.
                                Please verify decimal placement.
                            </p>

                        </div>

                    </div>

                    <div class="text-end">

                        <p class="text-warning fw-bold">
                            Awaiting technician correction
                        </p>

                        <a asp-controller="LabTechnician"
                           asp-action="CaptureResults"
                           class="btn-dark-custom me-2">

                            Review Result

                        </a>

                        <a asp-controller="LabTechnician"
                           asp-action="TestDetail"
                           class="btn-dark-custom">

                            View Detail

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>