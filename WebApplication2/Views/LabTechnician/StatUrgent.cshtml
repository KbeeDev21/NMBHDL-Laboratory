@{
    Layout = "~/Views/Shared/_LabTechLayout.cshtml";
    ViewData["Title"] = "STAT & Urgent Tests";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<link href="~/css/dashboardstyles.css" rel="stylesheet" />

<style>

    .page-container {
        padding: 0;
    }

    .card-dark {
        background: #102B4E;
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 20px;
        border: 1px solid #1B3E68;
    }

    .metric-card {
        background: #163A63;
        border-radius: 16px;
        padding: 25px;
        text-align: center;
        border: 1px solid #1B3E68;
        height: 100%;
        transition: 0.2s ease;
    }

        .metric-card:hover {
            transform: translateY(-3px);
            background: #1B4B7A;
        }

    .metric-number {
        font-size: 2.5rem;
        font-weight: bold;
    }

    .alert-banner {
        background: #f8d7da;
        color: #842029;
        border-left: 5px solid #dc3545;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .form-control,
    .form-select,
    .form-control:focus,
    .form-select:focus {
        background: #0B2447;
        color: #fff;
        border: 1px solid #355C8A;
        box-shadow: none;
    }

    .btn-dark-custom {
        background: #163A63;
        border: 1px solid #355C8A;
        color: white !important;
        border-radius: 12px;
        padding: 10px 20px;
        text-decoration: none;
        transition: 0.2s;
    }

        .btn-dark-custom:hover {
            background: #1B4B7A;
            border-color: #4d79a8;
        }

    .column-card {
        background: #163A63;
        border-radius: 16px;
        padding: 20px;
        height: 100%;
        border: 1px solid #1B3E68;
    }

    .test-card {
        background: #1B4B7A;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 15px;
        border-left: 4px solid #dc3545;
        transition: 0.2s ease;
    }

        .test-card:hover {
            transform: translateX(4px);
            background: #25598c;
        }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        margin-right: 5px;
        margin-top: 5px;
    }

    .badge-stat {
        background: #dc3545;
        color: white;
    }

    .badge-urgent {
        background: #f4a261;
        color: black;
    }

    .badge-done {
        background: #2d6a4f;
        color: white;
    }

    .test-card a {
        color: white;
        text-decoration: none;
    }

        .test-card a:hover {
            color: #cfe6ff;
        }

    .text-muted {
        color: #c5d3e0 !important;
    }

    h1,
    h5,
    strong {
        color: white;
    }

</style>


<!-- MAIN CONTENT -->
<div class="main-content">

    <div class="page-container">

        <div class="card-dark">

            <h1 class="mb-2">
                STAT & Urgent Tests
            </h1>

            <p class="text-muted">
                Live monitoring of high-priority laboratory requests.
            </p>

            <!-- KPI Cards -->
            <div class="row g-3 mb-4">

                <div class="col-md-2">

                    <div class="metric-card">

                        <div class="metric-number text-danger">
                            4
                        </div>

                        <div>
                            TAT Breached
                        </div>

                    </div>

                </div>

                <div class="col-md-2">

                    <div class="metric-card">

                        <div class="metric-number text-warning">
                            3
                        </div>

                        <div>
                            At Risk
                        </div>

                    </div>

                </div>

                <div class="col-md-2">

                    <div class="metric-card">

                        <div class="metric-number text-primary">
                            11
                        </div>

                        <div>
                            Active STAT Tests
                        </div>

                    </div>

                </div>

                <div class="col-md-2">

                    <div class="metric-card">

                        <div class="metric-number text-light">
                            8
                        </div>

                        <div>
                            Completed Today
                        </div>

                    </div>

                </div>

                <div class="col-md-2">

                    <div class="metric-card">

                        <div class="metric-number text-success">
                            38m
                        </div>

                        <div>
                            Avg TAT Today
                        </div>

                    </div>

                </div>

            </div>

            <!-- Alert -->
            <div class="alert-banner">

                <strong>
                    4 tests have breached their turnaround time.
                </strong>

                Immediate attention is required.

            </div>

            <!-- Filters -->
            <div class="mb-4">

                <input type="text"
                       class="form-control mb-3"
                       placeholder="Search patient, accession, or test..." />

                <div class="row g-3">

                    <div class="col-md-3">

                        <select class="form-select">

                            <option>All Priorities</option>
                            <option>STAT Only</option>
                            <option>Urgent Only</option>

                        </select>

                    </div>

                    <div class="col-md-3">

                        <select class="form-select">

                            <option>All Stages</option>
                            <option>Sample Received</option>
                            <option>Processing</option>
                            <option>Verification</option>
                            <option>Complete</option>

                        </select>

                    </div>

                    <div class="col-md-3">

                        <select class="form-select">

                            <option>All TAT</option>
                            <option>Breached</option>
                            <option>At Risk</option>
                            <option>Within TAT</option>

                        </select>

                    </div>

                    <div class="col-md-3 text-end">

                        <button class="btn-dark-custom me-2">
                            Board
                        </button>

                        <button class="btn-dark-custom">
                            List
                        </button>

                    </div>

                </div>

            </div>

            <!-- Kanban Board -->
            <div class="row g-3">

                <!-- Sample Received -->
                <div class="col-md-3">

                    <div class="column-card">

                        <h5>
                            Sample Received
                        </h5>

                        <div class="test-card">

                            <a asp-controller="LabTechnician"
                               asp-action="TestDetail">

                                <strong>
                                    Hendricks, Ayesha
                                </strong><br />

                                FBC

                            </a>

                            <div>

                                <span class="status-badge badge-urgent">
                                    Urgent
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- Processing -->
                <div class="col-md-3">

                    <div class="column-card">

                        <h5>
                            Processing
                        </h5>

                        <div class="test-card">

                            <a asp-controller="LabTechnician"
                               asp-action="TestDetail">

                                <strong>
                                    Baloyi, Thabo
                                </strong><br />

                                FBC + Diff

                            </a>

                            <div>

                                <span class="status-badge badge-stat">
                                    STAT
                                </span>

                            </div>

                        </div>

                        <div class="test-card">

                            <a asp-controller="LabTechnician"
                               asp-action="TestDetail">

                                <strong>
                                    Petersen, Riaan
                                </strong><br />

                                APTT

                            </a>

                            <div>

                                <span class="status-badge badge-stat">
                                    STAT
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- Verification -->
                <div class="col-md-3">

                    <div class="column-card">

                        <h5>
                            Verification
                        </h5>

                        <div class="test-card">

                            <a asp-controller="LabTechnician"
                               asp-action="TestDetail">

                                <strong>
                                    Van Wyk, Marius
                                </strong><br />

                                PT / INR

                            </a>

                            <div>

                                <span class="status-badge badge-stat">
                                    STAT
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- Complete -->
                <div class="col-md-3">

                    <div class="column-card">

                        <h5>
                            Complete
                        </h5>

                        <div class="test-card"
                             style="border-left-color:#2d6a4f;">

                            <a asp-controller="LabTechnician"
                               asp-action="TestDetail">

                                <strong>
                                    Adams, Charlene
                                </strong><br />

                                FBC + Diff

                            </a>

                            <div>

                                <span class="status-badge badge-done">
                                    Done
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Navigation -->
            <div class="mt-4">

                <a asp-controller="Home"
                   asp-action="LabTechnicianDashboard"
                   class="btn-dark-custom">

                    ← Back to Dashboard

                </a>

            </div>

        </div>

    </div>

</div>