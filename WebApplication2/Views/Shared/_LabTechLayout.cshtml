<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - NMB-HLabSys</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- LabTech CSS -->
    <link rel="stylesheet"
          href="~/css/labtech.css"
          asp-append-version="true" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">

        <!-- TOP -->
        <div class="sidebar-top">

            <div class="sidebar-profile">

                <i class="fa-solid fa-user"></i>

                <div class="profile-info">

                    <div class="profile-text">
                        Mr
                    </div>

                    <div class="profile-text">
                        Keenen James
                    </div>

                </div>

            </div>

            <div class="profile-role">
                Lab Technician
            </div>

        </div>

        <!-- BOTTOM -->
        <div class="sidebar-bottom">

            <div class="sidebar-section">
                WORKFLOW
            </div>

            <a asp-controller="Home"
               asp-action="LabTechnicianDashboard"
               class="sidebar-link">
                <i class="fa-solid fa-house me-2"></i>
                Dashboard
            </a>

            <a asp-controller="LabTechnician"
               asp-action="ReceiveSamples"
               class="sidebar-link">
                <i class="fa-solid fa-box-open me-2"></i>
                Receive Samples
            </a>

            <a asp-controller="LabTechnician"
               asp-action="AwaitingSelection"
               class="sidebar-link">
                <i class="fa-solid fa-clock me-2"></i>
                Awaiting Selection
            </a>

            <a asp-controller="LabTechnician"
               asp-action="AssignedTests"
               class="sidebar-link">
                <i class="fa-solid fa-vial me-2"></i>
                Assigned Tests
            </a>

            <a asp-controller="LabTechnician"
               asp-action="CaptureResults"
               class="sidebar-link">
                <i class="fa-solid fa-pen-to-square me-2"></i>
                Capture Results
            </a>

            <a asp-controller="LabTechnician"
               asp-action="VerificationQueue"
               class="sidebar-link">
                <i class="fa-solid fa-square-check me-2"></i>
                Verification Queue
            </a>

            <a asp-controller="LabTechnician"
               asp-action="ReviewQueue"
               class="sidebar-link">
                <i class="fa-solid fa-rotate me-2"></i>
                Review Queue
            </a>

            <div class="sidebar-section">
                MONITORING
            </div>

            <a asp-controller="LabTechnician"
               asp-action="StatUrgent"
               class="sidebar-link">
                <i class="fa-solid fa-bolt me-2"></i>
                STAT / Urgent
            </a>

            <a asp-controller="LabTechnician"
               asp-action="Escalations"
               class="sidebar-link">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                Escalations
            </a>

            <a asp-controller="LabTechnician"
               asp-action="Reports"
               class="sidebar-link">
                <i class="fa-solid fa-chart-column me-2"></i>
                Reports
            </a>

            <div class="sidebar-section">
                ACCOUNT
            </div>

            <a asp-controller="LabTechnician"
               asp-action="Profile"
               class="sidebar-link">
                <i class="fa-solid fa-user me-2"></i>
                Profile
            </a>

            <a asp-controller="LabTechnician"
               asp-action="EditProfile"
               class="sidebar-link">
                <i class="fa-solid fa-user-pen me-2"></i>
                Edit Profile
            </a>

            <a asp-controller="LabTechnician"
               asp-action="ChangePassword"
               class="sidebar-link">
                <i class="fa-solid fa-lock me-2"></i>
                Change Password
            </a>

        </div>

    </div>

    <!-- CONTENT -->
    <div class="main-content">

        @RenderBody()

    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>